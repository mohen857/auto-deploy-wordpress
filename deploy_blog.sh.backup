#!/bin/bash

###############################################################################
# WordPress一键自动化部署脚本
# 功能：在Ubuntu 22.04上自动部署LNMP + WordPress环境
# 作者：mohen
# 版本：1.0
# 使用说明：以root用户运行 ./deploy_blog.sh
###############################################################################


# 在脚本开头添加日志设置
LOG_FILE="deploy_blog_$(date +%Y%m%d_%H%M%S).log"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "=== 部署开始于 $(date) ==="

# 设置颜色输出，便于识别
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 打印带颜色的消息函数
print_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 检查上一条命令是否执行成功
check_status() {
    if [ $? -eq 0 ]; then
        print_info "$1 成功"
    else
        print_error "$1 失败"
        exit 1
    fi
}

###############################################################################
#                         配置参数
###############################################################################


# 服务器公网IP（用于Nginx配置）
SERVER_IP="yourip"  # 公网Ip

# MySQL相关配置
MYSQL_ROOT_PASSWORD="YourSecureRootPass123!"  # MySQL root密码，请修改
WP_DB_NAME="wordpress"                            # WordPress数据库名
WP_DB_USER="wordpressuser"                        # WordPress数据库用户
WP_DB_PASSWORD="YourSecureDBPass123!"      # WordPress数据库密码，请修改


# WordPress相关配置
WP_ADMIN_USER="admin"                             # WordPress管理员用户名
WP_ADMIN_PASSWORD="YourSecureAdminPass123!"       # WordPress管理员密码，请修改
WP_ADMIN_EMAIL="your-email@example.com"           # WordPress管理员邮箱，请修改
WP_SITE_TITLE="我的运维学习博客"                    # 网站标题

# 网站目录配置
WEB_ROOT="/var/www/wordpress"                     # WordPress安装目录
NGINX_CONF="/etc/nginx/sites-available/wordpress" # Nginx配置文件


# PHP版本（根据系统实际安装的PHP-FPM版本调整）
PHP_VERSION="8.1"


###############################################################################
#                         1. 系统更新与依赖安装
###############################################################################



print_info "开始 WordPress 一键自动化部署..."
print_info "当前时间: $(date)"
print_info "服务器IP: ${SERVER_IP}"


# 设置非交互模式，避免安装过程中弹出配置界面
export DEBIAN_FRONTEND=noninteractive
export NEEDRESTART_MODE=a

# 更新系统包列表
print_info "更新系统软件包列表..."
apt update -y
check_status "系统更新"

# 升级现有软件包
print_info "升级现有软件包..."
apt upgrade -y -o Dpkg::Options::="--force-confold"
check_status "软件包升级"

###############################################################################
#                         2. 安装Nginx Web服务器
###############################################################################


print_info "检查Nginx是否已安装..."
if ! command -v nginx &> /dev/null; then
    print_info "安装Nginx..."
    apt install nginx -y
    check_status "Nginx安装"
    
    # 启动并设置开机自启
    systemctl start nginx
    systemctl enable nginx
    check_status "Nginx服务启动"
else
    print_warn "Nginx已安装，跳过安装步骤"
fi

# 禁用默认站点（如果存在）
if [ -f /etc/nginx/sites-enabled/default ]; then
    print_info "禁用Nginx默认站点..."
    rm /etc/nginx/sites-enabled/default
    check_status "禁用默认站点"
fi

###############################################################################
#                         3. 安装MySQL数据库
###############################################################################


print_info "检查MySQL是否已安装..."
if ! command -v mysql &> /dev/null; then
    print_info "安装MySQL..."
    apt install mysql-server -y
    check_status "MySQL安装"
    
    # 启动并设置开机自启
    systemctl start mysql
    systemctl enable mysql
    check_status "MySQL服务启动"
else
    print_warn "MySQL已安装，跳过安装步骤"
fi


# 设置MySQL root密码（Ubuntu 22.04特殊处理）
print_info "配置MySQL root密码..."
mysql -e "ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY '${MYSQL_ROOT_PASSWORD}';" 2>/dev/null || true
mysql -e "FLUSH PRIVILEGES;" 2>/dev/null || true


# 运行MySQL安全配置（非交互式）
print_info "运行MySQL安全配置..."
SECURE_MYSQL=$(expect -c "
set timeout 10
spawn mysql_secure_installation
expect \"Press y|Y for Yes, any other key for No:\"
send \"n\r\"
expect \"New password:\"
send \"${MYSQL_ROOT_PASSWORD}\r\"
expect \"Re-enter new password:\"
send \"${MYSQL_ROOT_PASSWORD}\r\"
expect \"Remove anonymous users? (Press y|Y for Yes, any other key for No) :\"
send \"y\r\"
expect \"Disallow root login remotely? (Press y|Y for Yes, any other key for No) :\"
send \"y\r\"
expect \"Remove test database and access to it? (Press y|Y for Yes, any other key for No) :\"
send \"y\r\"
expect \"Reload privilege tables now? (Press y|Y for Yes, any other key for No) :\"
send \"y\r\"
expect eof
")

echo "$SECURE_MYSQL" | grep -q "All done!" && print_info "MySQL安全配置完成" || print_warn "MySQL安全配置可能未完全执行"


###############################################################################
#                         4. 安装PHP及相关扩展
###############################################################################


print_info "检查PHP是否已安装..."
if ! command -v php &> /dev/null; then
    print_info "安装PHP及相关扩展..."
    apt install php-fpm php-mysql php-curl php-gd php-mbstring php-xml php-xmlrpc php-zip php-soap php-intl -y
    check_status "PHP安装"
else
    print_warn "PHP已安装，跳过安装步骤"
fi

# 启动PHP-FPM
systemctl start php${PHP_VERSION}-fpm
systemctl enable php${PHP_VERSION}-fpm
check_status "PHP-FPM服务启动"


###############################################################################
#                         5. 为WordPress创建数据库和用户
###############################################################################


print_info "为WordPress创建数据库和用户..."


# 创建数据库
mysql -u root -p${MYSQL_ROOT_PASSWORD} -e "CREATE DATABASE IF NOT EXISTS ${WP_DB_NAME} DEFAULT CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" 2>/dev/null
check_status "创建数据库 ${WP_DB_NAME}"

# 创建用户并授权
mysql -u root -p${MYSQL_ROOT_PASSWORD} -e "CREATE USER IF NOT EXISTS '${WP_DB_USER}'@'localhost' IDENTIFIED BY '${WP_DB_PASSWORD}';" 2>/dev/null
mysql -u root -p${MYSQL_ROOT_PASSWORD} -e "GRANT ALL PRIVILEGES ON ${WP_DB_NAME}.* TO '${WP_DB_USER}'@'localhost';" 2>/dev/null
mysql -u root -p${MYSQL_ROOT_PASSWORD} -e "FLUSH PRIVILEGES;" 2>/dev/null
check_status "创建数据库用户 ${WP_DB_USER}"

print_info "数据库信息:"
print_info "  数据库名: ${WP_DB_NAME}"
print_info "  用户名: ${WP_DB_USER}"
print_info "  密码: ${WP_DB_PASSWORD}"

###############################################################################
#                         6. 下载并配置WordPress
###############################################################################

print_info "准备安装WordPress..."

# 如果目录已存在，先备份
if [ -d "${WEB_ROOT}" ]; then
    print_warn "WordPress目录已存在，创建备份..."
    backup_dir="${WEB_ROOT}_backup_$(date +%Y%m%d_%H%M%S)"
    mv "${WEB_ROOT}" "${backup_dir}"
    print_info "原目录已备份到: ${backup_dir}"
fi


# 进入Web根目录
cd /var/www


# 下载最新版WordPress
print_info "下载WordPress..."
wget -q https://wordpress.org/latest.tar.gz
check_status "下载WordPress"


# 解压
print_info "解压WordPress..."
tar -xzf latest.tar.gz
check_status "解压WordPress"


# 清理压缩包
rm latest.tar.gz


# 设置权限
print_info "设置WordPress目录权限..."
chown -R www-data:www-data "${WEB_ROOT}"
find "${WEB_ROOT}" -type d -exec chmod 755 {} \;
find "${WEB_ROOT}" -type f -exec chmod 644 {} \;
check_status "权限设置"

# 创建wp-config.php配置文件
print_info "创建WordPress配置文件..."
cp "${WEB_ROOT}/wp-config-sample.php" "${WEB_ROOT}/wp-config.php"

# 使用sed替换数据库配置
sed -i "s/database_name_here/${WP_DB_NAME}/g" "${WEB_ROOT}/wp-config.php"
sed -i "s/username_here/${WP_DB_USER}/g" "${WEB_ROOT}/wp-config.php"
sed -i "s/password_here/${WP_DB_PASSWORD}/g" "${WEB_ROOT}/wp-config.php"
check_status "WordPress配置"


###############################################################################
#                         7. 配置Nginx虚拟主机
###############################################################################


print_info "配置Nginx虚拟主机..."

# 创建Nginx配置文件
cat > ${NGINX_CONF} << EOF
server {
    listen 80;
    listen [::]:80;
    
    server_name ${SERVER_IP};
    
    root ${WEB_ROOT};
    index index.php index.html index.htm;
    
    location / {
        try_files \$uri \$uri/ /index.php?\$args;
    }
    
    location ~ \.php\$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php${PHP_VERSION}-fpm.sock;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }
    
    location ~ /\.ht {
        deny all;
    }
    
    location = /favicon.ico { 
        log_not_found off; 
        access_log off; 
    }
    
    location = /robots.txt { 
        log_not_found off; 
        access_log off; 
        allow all; 
    }
    
    location ~* \.(css|gif|ico|jpeg|jpg|js|png)\$ {
        expires max;
        log_not_found off;
    }
}
EOF

check_status "创建Nginx配置文件"

# 启用站点
if [ ! -L /etc/nginx/sites-enabled/wordpress ]; then
    ln -s ${NGINX_CONF} /etc/nginx/sites-enabled/
fi

# 测试Nginx配置
print_info "测试Nginx配置..."
nginx -t
check_status "Nginx配置测试"


# 重载Nginx配置
print_info "重载Nginx配置..."
systemctl reload nginx
check_status "Nginx重载"

###############################################################################
#                         8. 自动安装WordPress
###############################################################################

print_info "开始自动安装WordPress..."

# 检查是否可以通过curl访问安装页面
print_info "等待WordPress安装页面就绪..."
sleep 5  # 给Nginx一点时间

# 尝试自动完成WordPress安装（通过WP-CLI）
if ! command -v wp &> /dev/null; then
    print_info "安装WP-CLI..."
    curl -O https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar
    chmod +x wp-cli.phar
    mv wp-cli.phar /usr/local/bin/wp
    check_status "WP-CLI安装"
fi


# 进入WordPress目录
cd "${WEB_ROOT}"


# 使用WP-CLI完成WordPress安装
print_info "通过WP-CLI安装WordPress..."
wp core install --url="http://${SERVER_IP}" \
                --title="${WP_SITE_TITLE}" \
                --admin_user="${WP_ADMIN_USER}" \
                --admin_password="${WP_ADMIN_PASSWORD}" \
                --admin_email="${WP_ADMIN_EMAIL}" \
                --skip-email \
                --allow-root 2>/dev/null

if [ $? -eq 0 ]; then
    print_info "WordPress自动安装成功！"
else
    print_warn "WordPress自动安装失败，可能需要手动完成安装"
    print_info "请访问 http://${SERVER_IP} 完成WordPress安装"
fi

###############################################################################
#                         9. 安装完成，输出总结信息
###############################################################################

echo ""
echo "================================================================"
print_info "🎉 WordPress一键自动化部署完成！"
echo "================================================================"
echo ""
print_info "网站访问地址: http://${SERVER_IP}"
print_info "WordPress后台: http://${SERVER_IP}/wp-admin"
echo ""
print_info "管理员账号: ${WP_ADMIN_USER}"
print_info "管理员密码: ${WP_ADMIN_PASSWORD}"
echo ""
print_info "数据库信息:"
print_info "  数据库名: ${WP_DB_NAME}"
print_info "  用户名: ${WP_DB_USER}"
print_info "  密码: ${WP_DB_PASSWORD}"
echo ""
print_info "MySQL root密码: ${MYSQL_ROOT_PASSWORD}"
echo ""
print_warn "⚠️  请立即修改所有密码并妥善保管！"
print_warn "⚠️  建议配置防火墙和安全组，仅开放必要端口！"
echo ""
print_info "部署完成时间: $(date)"
echo "================================================================"

# 导入配置
source ./deploy_config.sh
